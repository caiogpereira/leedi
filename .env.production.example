# =============================================================================
# Leedi — PRODUCTION env (PL-2)
# =============================================================================
# Source of truth for required vars: packages/config/src/schema.ts
#
# WHERE THIS GOES: these are set in the host's environment, NOT committed.
# On Vercel: Project → Settings → Environment Variables → Production scope, for
# EACH deployed app (web, dashboard, admin, api). This file is just the
# fill-in template — keep it out of the real secret store.
#
# Legend:
#   [GERAR]    → you generate it in the terminal (command shown)
#   [PROVEDOR] → copy from the provider's dashboard
#   [TROCAR]   → ⚠️ you ALREADY have a sandbox/test value — swap it for the
#                PRODUCTION one before launch
# =============================================================================

NODE_ENV=production

# ── Banco de dados (Supabase produção) ───────────────────────────────────────
# [PROVEDOR] Supabase prod → Project Settings → Database → Connection string.
DATABASE_URL=postgresql://postgres:<SENHA>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Opcional: só quando migrar pro Supabase Pro (Dedicated Pooler) e habilitar a
# RLS no nível do banco (PL-3). Aponta para o role leedi_app (não-BYPASSRLS).
# APP_DATABASE_URL=

# ── Observabilidade ──────────────────────────────────────────────────────────
SENTRY_DSN=https://<public-key>@<org-id>.ingest.us.sentry.io/<api-project-id>   # [PROVEDOR] Sentry (DSN do leedi-api)
POSTHOG_KEY=phc_xxx                                                              # [PROVEDOR] PostHog
BETTER_STACK_TOKEN=xxx                                                           # [PROVEDOR] Better Stack (Sources → token)

# ── Auth / origens (https reais) ─────────────────────────────────────────────
BETTER_AUTH_SECRET=                 # [GERAR] openssl rand -hex 32   (mín. 32 chars)
BETTER_AUTH_URL=https://app.leedi.com        # origem do WEB app (login)
DASHBOARD_URL=https://dashboard.leedi.com
ADMIN_URL=https://admin.leedi.com
# Origem PÚBLICA que encaminha para a API (fix do PL-14a). Em prod multi-host,
# defina explicitamente — sem isso a derivação :3000→API_PORT quebra os callbacks.
API_PUBLIC_URL=https://api.leedi.com
API_PORT=3003
WORKSPACE_ID=<uuid-do-seu-workspace>

# ── Criptografia ─────────────────────────────────────────────────────────────
ENCRYPTION_MASTER_KEY=              # [GERAR] openssl rand -base64 32  (32 bytes em base64)

# ── Redis / filas (Upstash) ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://<...>.upstash.io      # [PROVEDOR] Upstash
UPSTASH_REDIS_REST_TOKEN=                            # [PROVEDOR] Upstash
QSTASH_TOKEN=                                        # [PROVEDOR] Upstash QStash
QSTASH_CURRENT_SIGNING_KEY=                          # [PROVEDOR] Upstash QStash
QSTASH_NEXT_SIGNING_KEY=                             # [PROVEDOR] Upstash QStash

# ── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx                         # [PROVEDOR] Anthropic
# Transcrição de áudio (opcional — só se for usar áudio).
TRANSCRIPTION_PROVIDER=groq
# GROQ_API_KEY=
# OPENAI_API_KEY=

# ── E-mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx                                # [PROVEDOR] Resend

# ── WhatsApp / Meta ──────────────────────────────────────────────────────────
# ⚠️ [TROCAR] hoje você usa o App de teste da Meta. Para produção, use o App
# Meta aprovado (App Review concluído) e o número de produção.
WHATSAPP_API_VERSION=v20.0
WHATSAPP_APP_SECRET=                 # [TROCAR][PROVEDOR] Meta Developer App → Settings → Basic → App Secret (do app de PRODUÇÃO)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=       # [GERAR] openssl rand -hex 16  (use o MESMO valor ao registrar o webhook na Meta)

# ── Billing (Asaas) ──────────────────────────────────────────────────────────
# ⚠️ [TROCAR] hoje em sandbox. Para produção: ASAAS_SANDBOX=false + chave de PRODUÇÃO.
ASAAS_API_KEY=                       # [TROCAR][PROVEDOR] Asaas → Configurações → Integrações → API Key de PRODUÇÃO
ASAAS_SANDBOX=false                  # ⚠️ false em produção
ASAAS_WEBHOOK_TOKEN=                 # [GERAR] openssl rand -hex 16  (configure o MESMO valor no webhook do Asaas)

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# [GERAR] npx web-push generate-vapid-keys  (gera o par público/privado de uma vez)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@leedi.com
# ⚠️ CRÍTICO (pegadinha do PL-2): no build/runtime do apps/dashboard, defina
# NEXT_PUBLIC_VAPID_PUBLIC_KEY = MESMO valor de VAPID_PUBLIC_KEY. É embutido no
# bundle em tempo de compilação; se faltar, o push falha em SILÊNCIO (sem erro).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Admin dashboard ──────────────────────────────────────────────────────────
USD_TO_BRL_RATE=5.0                  # taxa fixa USD→BRL; ajuste manualmente quando mover muito
