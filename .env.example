# Application
NODE_ENV=development

# Database (Supabase)
# Direct connection for migrations; Supabase pooler for runtime (see packages/db/src/client.ts)
# DATABASE_URL is the PRIVILEGED/service connection (Supabase `postgres`, BYPASSRLS) —
# used by direct `db` access and the deliberate `withServiceRole` bypass path.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# RLS-enforced application connection (Story 2.4 / Workstream B). OPTIONAL.
# When set, the `withTenant`/`withUser` tenant-data path connects as a NON-BYPASSRLS
# role (`leedi_app`) so RLS policies are actually enforced. When unset, that path
# falls back to DATABASE_URL (RLS bypassed — current behavior). Provision: set the
# leedi_app password in Supabase, then point this at it via the pooler.
# APP_DATABASE_URL=postgresql://leedi_app:password@<pooler-host>:6543/postgres

# Sentry DSNs — one per app (configure each app's real DSN in its runtime env, NOT here)
# Use placeholders only in this committed example. Real DSNs live in .env (gitignored)
# or in the host/CI secret store.
SENTRY_DSN=https://<public-key>@<org-id>.ingest.us.sentry.io/<project-id>
# leedi-web:       https://<public-key>@<org-id>.ingest.us.sentry.io/<web-project-id>
# leedi-dashboard: https://<public-key>@<org-id>.ingest.us.sentry.io/<dashboard-project-id>
# leedi-admin:     https://<public-key>@<org-id>.ingest.us.sentry.io/<admin-project-id>
# leedi-api:       https://<public-key>@<org-id>.ingest.us.sentry.io/<api-project-id>

# PostHog
POSTHOG_KEY=phc_examplekey

# Better Stack (Logs)
BETTER_STACK_TOKEN=your_source_token

# API
API_PORT=3003

# Better-Auth
BETTER_AUTH_SECRET=generate-a-32-char-random-string
BETTER_AUTH_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001
# Public origin of the API, used to build callback URLs that external services
# (Meta webhooks, QStash jobs) call back into (PL-14). Leave UNSET for local
# single-host dev (it is derived from BETTER_AUTH_URL by swapping :3000→:API_PORT).
# Set to a tunnel that forwards to the API port for Tier-1 / staging testing.
# API_PUBLIC_URL=https://your-tunnel.example.com
# Internal origin of the API, used by the dashboard's BFF proxy routes for
# server-to-server calls into the Hono API (PL-14b). DISTINCT from API_PUBLIC_URL:
# in prod this is plausibly a private service URL, not the public tunnel. Leave
# UNSET for local single-host dev (derived from BETTER_AUTH_URL :3000→:API_PORT).
# INTERNAL_API_URL=http://api.internal:3003

# Resend (email)
RESEND_API_KEY=re_...

# Upstash Redis (rate limiting + session)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Workspace — the single platform workspace (created once via SQL seed)
WORKSPACE_ID=your-workspace-uuid-here

# WhatsApp / Meta Cloud API
# Generate a 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=your-base64-32-byte-key-here
WHATSAPP_API_VERSION=v20.0
# App Secret from Meta Developer App (App Settings > Basic) — used to verify webhook HMAC signatures
WHATSAPP_APP_SECRET=placeholder-get-from-meta-developer-app
# A token YOU choose and set in the Meta Developer App when registering the webhook URL
WHATSAPP_WEBHOOK_VERIFY_TOKEN=leedi-webhook-verify-dev

# Upstash QStash (scheduled jobs + debounce flush)
# https://console.upstash.com/qstash — Tokens tab
QSTASH_TOKEN=placeholder-get-from-upstash-qstash
QSTASH_CURRENT_SIGNING_KEY=placeholder-get-from-upstash-qstash
QSTASH_NEXT_SIGNING_KEY=placeholder-get-from-upstash-qstash

# Asaas Billing (Story 17.1)
# Get from https://asaas.com or https://sandbox.asaas.com
ASAAS_API_KEY=
ASAAS_SANDBOX=true
# A token YOU choose; set the same value in the Asaas webhook configuration
ASAAS_WEBHOOK_TOKEN=

# Web Push / VAPID (Story 18.1)
# Generate once: npx web-push generate-vapid-keys
# IMPORTANT: Never regenerate after users subscribe — existing subscriptions will break.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: or https: URL that identifies your push service contact
VAPID_SUBJECT=mailto:suporte@leedi.digital
# Browser-exposed copy of VAPID_PUBLIC_KEY (must be identical). The dashboard inlines
# NEXT_PUBLIC_* at compile time to build the push subscription; if unset, registration no-ops.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Admin operational dashboard (Story 20.3)
# Fixed USD->BRL rate for the estimated-margin KPI. Update manually when the rate
# moves significantly (V1 has no live FX feed).
USD_TO_BRL_RATE=5.0