# Application
NODE_ENV=development

# Database (Supabase)
# Direct connection for migrations; Supabase pooler for runtime (see packages/db/src/client.ts)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Sentry DSNs — one per app (configure in each app's runtime env)
# leedi-api (Node/Hono)
SENTRY_DSN=https://xxx@yyy.ingest.us.sentry.io/zzz
# leedi-web:       https://516b4929f5171d49fbc3cfe857e1f927@o4511212929679360.ingest.us.sentry.io/4511474954665984
# leedi-dashboard: https://2e4bf8c4c881dbd955b0444b9e9228a4@o4511212929679360.ingest.us.sentry.io/4511474971574272
# leedi-admin:     https://1d8c91a29c367391a307d5ff657fa761@o4511212929679360.ingest.us.sentry.io/4511474976030720
# leedi-api:       https://90896d87b5c7b24e152e1960ca63c05e@o4511212929679360.ingest.us.sentry.io/4511474982060032

# PostHog
POSTHOG_KEY=phc_examplekey

# Better Stack (Logs)
BETTER_STACK_TOKEN=your_source_token

# API
API_PORT=3003