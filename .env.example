# Application
NODE_ENV=development

# Database (Supabase)
# Direct connection for migrations; Supabase pooler for runtime (see packages/db/src/client.ts)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Sentry DSNs — one per app (configure in each app's runtime env)
# leedi-api (Node/Hono)
SENTRY_DSN=https://xxx@yyy.ingest.us.sentry.io/zzz
# leedi-web:       ***REDACTED-SENTRY-DSN***
# leedi-dashboard: ***REDACTED-SENTRY-DSN***
# leedi-admin:     ***REDACTED-SENTRY-DSN***
# leedi-api:       ***REDACTED-SENTRY-DSN***

# PostHog
POSTHOG_KEY=phc_examplekey

# Better Stack (Logs)
BETTER_STACK_TOKEN=your_source_token

# API
API_PORT=3003

# Better-Auth
BETTER_AUTH_SECRET=generate-a-32-char-random-string
BETTER_AUTH_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001

# Resend (email)
RESEND_API_KEY=re_...

# Upstash Redis (rate limiting + session)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Workspace — the single platform workspace (created once via SQL seed)
WORKSPACE_ID=your-workspace-uuid-here