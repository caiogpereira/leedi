{
  "extends": "@leedi/tsconfig/nextjs.json",
  "include": [
    "app",
    "components",
    "lib",
    "middleware.ts",
    "src",
    "next.config.ts",
    "tailwind.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ],
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "incremental": true
  }
}
